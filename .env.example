LLM_PROVIDER=mock
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3-agent-lora

QWEN3_BASE_MODEL_PATH=/data/models/Qwen3
QWEN3_LORA_OUTPUT_DIR=/data/outputs/qwen3-agent-lora
QWEN3_MERGED_MODEL_DIR=/data/outputs/qwen3-agent-merged

TRAIN_DATA_PATH=data/sft/train.jsonl
VAL_DATA_PATH=data/sft/val.jsonl

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=120

RAG_TOP_K=5
RAG_MIN_SCORE=0.12

AGENT_USE_LLM_PLANNER=true
AGENT_USE_LLM_ANSWER_BUILDER=true
